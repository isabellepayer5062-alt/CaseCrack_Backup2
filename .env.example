# Copy this file to .env and fill in your real values
# Then: source .env   (or load it in WSL)

# === LLM API KEYS (required) ===
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...

# === OpenClaw Webhook (optional but recommended for pipeline) ===
OPENCLAW_WEBHOOK_TOKEN=your-super-secret-random-token-here-32-chars-min

# === Paths (match your OS/WSL) ===
ROOT_SCOPE_FILE=/bb/scope/roots.txt
BASE_INCOMING_DIR=/bb/incoming

# === Optional tuning ===
OPENCLAW_CONFIG=./openclaw.json

# === Venator MCP HTTP transport (only needed for WSL2/Kali HTTP mode) ===
# On Windows, openclaw spawns Venator as a stdio subprocess (no vars needed).
# In WSL2/Kali, set these to expose Venator over HTTP so the openclaw agent
# can reach it. Then change mcp.servers.venator-recon-suite in
# ~/.openclaw/openclaw.json to: {"url": "http://127.0.0.1:9191"}
MCP_HTTP_ENABLED=false         # set to true in WSL2/Kali HTTP mode
MCP_HTTP_PORT=9191             # must match the url in openclaw mcp config
MCP_AUTH_ENABLED=false         # loopback-only; keep false for local use
